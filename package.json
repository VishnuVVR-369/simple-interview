{
  "name": "simple-interview",
  "private": true,
  "scripts": {
    "build": "bun --env-file=.env turbo run build",
    "dev": "bun --env-file=.env turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "start": "bun --env-file=.env turbo run start",
    "all": "bun run lint && bun run format && bun run check-types && bun run build"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
